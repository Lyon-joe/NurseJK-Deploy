PORT=3001

# MongoDB Connection String (REQUIRED)
# Get from: https://www.mongodb.com/cloud/atlas (free tier available)
# Format: mongodb+srv://username:password@cluster.mongodb.net/nursing-ai?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://user:password@your-cluster.mongodb.net/nursing-ai?retryWrites=true&w=majority

# JWT Secret for authentication (REQUIRED)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# OpenAI API Key (optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Gemini API Key (optional)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Environment
NODE_ENV=development
