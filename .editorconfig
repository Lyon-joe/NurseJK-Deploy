# EditorConfig helps enforce consistent coding styles

root = true

# All files
[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Markdown
[*.md]
trim_trailing_whitespace = false

# JSON
[*.json]
indent_size = 2

# TypeScript/JavaScript
[*.{js,jsx,ts,tsx}]
indent_size = 2

# Shell scripts
[*.sh]
end_of_line = lf
